# GoAPI - data historis IDX (fallback kalau Yahoo Finance gagal)
# Daftar di https://goapi.id
GOAPI_TOKEN=your_goapi_token_here
GOAPI_BASE=https://api.goapi.io

# Stockbit - data harga real-time (override Yahoo yang delay 15 menit)
# Token dari Stockbit web - DevTools > Network > cari Bearer token
STOCKBIT_TOKEN=your_stockbit_jwt_here

# Port server (default 3000)
PORT=3000
